# Personal settings for mts-link-chat-sync.
# Copy this file to `.env` and edit. `.env` is gitignored — nothing personal is committed.
# All keys are OPTIONAL; sensible defaults apply if you leave them out.

# Where exported chat markdown + the watched-chats registry go.
# Relative paths are anchored to the tool dir; `~/` and absolute paths also work.
# Default: ./chats-out
# CHAT_SYNC_OUTPUT_DIR=~/mts-link-chats

# Registry file (list of watched chats). Default: <OUTPUT_DIR>/watched-chats.yaml
# CHAT_SYNC_REGISTRY=~/mts-link-chats/watched-chats.yaml

# Saved browser session created by `npm run login`. Personal SSO secret — keep it
# outside any git repo. Default: ~/.mts-link-chat-sync/auth.json
# CHAT_SYNC_AUTH_FILE=~/.mts-link-chat-sync/auth.json

# Chats web app entry point / login URL. Override only for a different MTS Link instance.
# CHAT_SYNC_CHATS_URL=https://my.mts-link.ru/chats/
# CHAT_SYNC_LOGIN_URL=https://my.mts-link.ru/
