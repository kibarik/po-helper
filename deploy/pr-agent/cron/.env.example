# PR-Agent config for self-hosted review. Copy to `.env`, fill secrets.
# Env vars use PR-Agent's dot notation (same keys as the old GHA workflow).
# `.env` is git-ignored — never commit real keys.

# --- LLM (z.ai GLM-5, same as the old workflow) ---
OPENAI.KEY=REPLACE_WITH_ZAI_API_KEY
OPENAI.API_BASE=https://api.z.ai/api/coding/paas/v4
CONFIG.MODEL=openai/glm-5
CONFIG.MODEL_TURBO=openai/glm-5
CONFIG.FALLBACK_MODELS=["openai/glm-5"]
CONFIG.CUSTOM_MODEL_MAX_TOKENS=128000

# --- GitHub ---
# PAT with `repo` scope (classic) or fine-grained: Pull requests RW + Contents RO.
# Comments are posted as whoever owns this token. Use a bot account for a clean
# author, or your own account to move fast.
GITHUB.USER_TOKEN=REPLACE_WITH_GITHUB_PAT
GITHUB.DEPLOYMENT_TYPE=user
CONFIG.GIT_PROVIDER=github

# Review behavior (language, focus, N suggestions) lives in the repo-root
# .pr_agent.toml — committed, no secrets. Nothing to set here for that.
