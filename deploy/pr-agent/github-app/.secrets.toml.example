# Copy to .secrets.toml (git-ignored) and fill in. Mounted into the container
# at /app/pr_agent/settings/.secrets.toml. Holds everything sensitive/infra.

[openai]
key = "REPLACE_WITH_ZAI_API_KEY"
api_base = "https://api.z.ai/api/coding/paas/v4"

# LLM selection (z.ai GLM-5, same as the old workflow). Kept here so the whole
# server config is self-contained on the box; review *behavior* is in the
# committed repo-root .pr_agent.toml.
[config]
model = "openai/glm-5"
model_turbo = "openai/glm-5"
fallback_models = ["openai/glm-5"]
custom_model_max_tokens = 128000

[github]
# --- App mode (webhook) ---
deployment_type = "app"
app_id = "REPLACE_WITH_APP_ID"
webhook_secret = "REPLACE_WITH_WEBHOOK_SECRET"   # the random hex you generated
# Paste the whole downloaded .pem, including BEGIN/END lines, between the quotes.
private_key = """
-----BEGIN RSA PRIVATE KEY-----
REPLACE_WITH_PRIVATE_KEY_CONTENTS
-----END RSA PRIVATE KEY-----
"""
